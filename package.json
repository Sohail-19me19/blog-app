{
  "name": "blog-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run prisma-generate && next dev --turbopack",
    "build": "npm run prisma-generate && next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "prisma-generate": "npx prisma generate --schema=src/db/schema.prisma",
    "prisma-studio": "npx prisma studio --schema=src/db/schema.prisma",
    "prisma-push": "npx prisma db push --schema=src/db/schema.prisma"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.1",
    "@mui/icons-material": "^7.3.1",
    "@mui/material": "^7.3.1",
    "@prisma/client": "^6.15.0",
    "@tanstack/react-query": "^5.85.6",
    "bcryptjs": "^3.0.2",
    "next": "15.5.2",
    "next-auth": "^5.0.0-beta.29",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.62.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "prisma": "^6.15.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
