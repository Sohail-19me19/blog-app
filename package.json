{
  "name": "blog-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "npm run prisma-generate && next dev",
    "build": "npm run prisma-generate && next build",
    "start": "next start",
    "lint": "eslint",
    "prisma-generate": "npx prisma generate --schema=src/db/schema.prisma",
    "prisma-studio": "npx prisma studio --schema=src/db/schema.prisma",
    "prisma-push": "npx prisma db push --schema=src/db/schema.prisma",
    "postinstall": "npm run prisma-generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.1",
    "@mui/icons-material": "7.2.0",
    "@mui/material": "7.2.0",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.85.6",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.3.1",
    "next": "14.2.7",
    "next-auth": "^5.0.0-beta.29",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.62.0",
    "sharp": "^0.34.5",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.7",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
